# ============================================================================
# EODI.ME — Environment Variables
# ============================================================================
# Copy to .env before deploying:  cp .env.example .env
# NEVER commit .env to version control!
#
# Required secrets — generate with: openssl rand -hex 32
# ============================================================================

# ── Engine Server (Rust) ─────────────────────────────────────────────────────
ENGINE_API_KEY=change_me_use_openssl_rand_hex_32
ENGINE_PLAN=pro
ENGINE_PORT=7557

# ── Caddy HTTPS (docker compose --profile https up) ──────────────────────────
DOMAIN=api.eodi.me

# ── Go API ────────────────────────────────────────────────────────────────────
# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
GIN_MODE=release

# Auth — generate: openssl rand -hex 32 (minimum 32 chars, must not contain "change"/"secret"/"default")
JWT_SECRET=replace_with_random_64_hex_chars_openssl_rand_hex_32
TOKEN_EXPIRY=24h

# Rate limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# CORS (required in release mode, must be explicit — not wildcard)
ALLOW_ORIGIN=https://your-domain.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Database paths
DB_PATH=data/vibe_data.db
HEX_DB_PATH=data/hexagons.edbh

# Redis (optional — leave empty to use in-memory rate limiting)
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# ── Monitoring (docker compose --profile monitoring up) ──────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_use_openssl_rand_hex_16

# ── Alertmanager notifications ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_TO=ops@eodi.me
ALERT_EMAIL_FROM=alerts@eodi.me
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Supabase (LEGACY — LemonSqueezy webhook, not used with current Polar setup) ──
# These are only needed if you deploy the supabase/functions/lemon-webhook Edge Function.
# Current desktop app uses Polar for payments and validates licenses locally.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── Data Collection APIs (rust-collector) ────────────────────────────────────
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_RATE_LIMIT=3
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
# Toggle climate collection. Default: disabled to speed up collection and reduce API usage.
# Set to 1 or true to enable historical climate collection (Open-Meteo / NASA POWER).
EODI_ENABLE_CLIMATE=false
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
NOMINATIM_RATE_LIMIT=1