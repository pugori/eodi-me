# ============================================================
# EODI.ME Go API — Environment Variables
# Copy this file to .env and fill in all required values.
# DO NOT commit the actual .env file to version control.
# ============================================================

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
GIN_MODE=release

# Database
DB_PATH=../data/vibe_data.db
# Toggle climate collection for collector (affects VDB build). Default: disabled.
EODI_ENABLE_CLIMATE=false

# Authentication — REQUIRED: generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS
TOKEN_EXPIRY=24h

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Redis — REQUIRED in production
REDIS_ADDR=redis:6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_DB=0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS — restrict to your domain(s) in production
ALLOW_ORIGIN=https://yourdomain.com
