# Normalize line endings to LF in the repository (cross-platform project)
* text=auto eol=lf

# Rust
*.rs text eol=lf
*.toml text eol=lf

# Go
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Python
*.py text eol=lf

# TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf

# Config/Docs
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.env text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files — do not modify
*.png binary
*.ico binary
*.icns binary
*.db binary
*.edb binary
*.edbh binary
*.ckpt binary
*.hex_poi_ckpt binary
*.poi_ckpt binary
*.exe binary
*.dll binary
*.pdb binary
*.lib binary
